{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/eap", "destination": "/index.html" },
    { "source": "/eap/", "destination": "/index.html" },
    { "source": "/eap/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/eap/favicon.png", "destination": "/favicon.png" },
    { "source": "/eap/logo-alta.svg", "destination": "/logo-alta.svg" },
    { "source": "/eap/bg--webp.webp", "destination": "/bg--webp.webp" },
    { "source": "/eap/bg-mobile.webp", "destination": "/bg-mobile.webp" },
    { "source": "/eap/foto-historia.webp", "destination": "/foto-historia.webp" },
    { "source": "/eap/foto-historia-mobile.webp", "destination": "/foto-historia-mobile.webp" },
    { "source": "/eap/talita-bonus.webp", "destination": "/talita-bonus.webp" },
    { "source": "/eap/:path*", "destination": "/index.html" }
  ]
}
