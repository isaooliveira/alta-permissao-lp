# Supabase — copie do painel: Settings > API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Supabase Service Role — usado APENAS na API Route do webhook (nunca no frontend)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Hotmart Webhook — copie de: Ferramentas > Webhooks > Hottok
HOTMART_WEBHOOK_SECRET=seu-hottok-aqui
